# SPDX-License-Identifier: BSL-1.0

BasedOnStyle: Alfa
ColumnLimit: 36
SoftColumnLimit: 28

Indent:
  Width: 2
  ContinuationWidth: 6
  CaseLabels: true

Braces:
  Declarations: allman
  Aggregates: knr
  Enums: otbs
  Functions: stroustrup
  FunctionLiterals: allman
  ControlStatements: knr

Spacing:
  BeforeBraces: false
  AroundBinaryOperators: false

Wrapping:
  BinaryOperators: before
  NewlinePenalty: 240
  LongLinePenalty: 50
