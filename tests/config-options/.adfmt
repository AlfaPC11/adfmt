# SPDX-License-Identifier: BSL-1.0

BasedOnStyle: Alfa
ColumnLimit: 36
SoftColumnLimit: 28

Indent:
  Width: 2
  ContinuationWidth: 6
  CaseLabels: true

Braces:
  Declarations: Allman
  Aggregates: Knr
  Enums: Otbs
  Functions: Stroustrup
  FunctionLiterals: Allman
  ControlStatements: Knr

Spacing:
  BeforeBraces: false
  AroundBinaryOperators: false

Wrapping:
  BinaryOperators: Before
  NewlinePenalty: 240
  LongLinePenalty: 50
